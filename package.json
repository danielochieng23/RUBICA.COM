    "frontend:build": "cd frontend && npm run build"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "web3": "^4.2.2",
    "ethers": "^6.8.1",
    "@truffle/contract": "^4.6.31",
    "circomlib": "^2.0.5",
    "snarkjs": "^0.7.2",
    "crypto": "^1.0.1",
    "elliptic": "^6.5.4",
    "merkletreejs": "^0.3.11",
    "ipfs-http-client": "^60.0.1",
    "mongodb": "^6.3.0",
    "mongoose": "^8.0.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1",
    "joi": "^17.11.0",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "redis": "^4.6.10"
