<%- include('../partials/header') %>

<main class="container py-5">
    <h1>Post New Ad</h1>
    
    <% if (error) { %>
        <div class="alert alert-error">
            <%= error %>
        </div>
    <% } %>
    
    <form action="/listings/new/create" method="POST" enctype="multipart/form-data">
        <div class="row">
            <div class="col-md-8">
                <h3>Basic Information</h3>
                
                <div class="form-group">
                    <label for="title" class="form-label">Title *</label>
                    <input type="text" id="title" name="title" class="form-control" required maxlength="100">
                </div>
                
                <div class="form-group">
                    <label for="description" class="form-label">Description *</label>
                    <textarea id="description" name="description" class="form-control" rows="5" required maxlength="2000"></textarea>
                </div>
                
                <div class="form-group">
                    <label for="category" class="form-label">Category *</label>
                    <select id="category" name="category" class="form-control" required>
                        <option value="">Select Category</option>
                        <option value="call-girls">Call Girls</option>
                        <option value="massages">Massages</option>
                        <option value="male-escorts">Male Escorts</option>
                        <option value="transsexual">Transsexual</option>
                        <option value="adult-meetings">Adult Meetings</option>
                    </select>
                </div>
                
                <h3 class="mt-4">Location</h3>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="city" class="form-label">City *</label>
                            <select id="city" name="city" class="form-control" required>
                                <option value="">Select City</option>
                                <option value="Mumbai">Mumbai</option>
                                <option value="Delhi">Delhi</option>
                                <option value="Bangalore">Bangalore</option>
                                <option value="Kolkata">Kolkata</option>
                                <option value="Chennai">Chennai</option>
                                <option value="Hyderabad">Hyderabad</option>
                                <option value="Pune">Pune</option>
                                <option value="Ahmedabad">Ahmedabad</option>
                                <option value="Jaipur">Jaipur</option>
                                <option value="Goa">Goa</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="area" class="form-label">Area</label>
                            <input type="text" id="area" name="area" class="form-control">
                        </div>
                    </div>
                </div>
                
                <h3 class="mt-4">Contact Information</h3>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="phone" class="form-label">Phone Number *</label>
                            <input type="tel" id="phone" name="phone" class="form-control" required>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="whatsapp" class="form-label">WhatsApp</label>
                            <input type="tel" id="whatsapp" name="whatsapp" class="form-control">
                        </div>
                    </div>
                </div>
                
                <div class="form-check">
                    <input type="checkbox" id="hidePhone" name="hidePhone" class="form-check-input">
                    <label for="hidePhone" class="form-check-label">Hide phone number in listing</label>
                </div>
                
                <h3 class="mt-4">Pricing</h3>
                
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="price" class="form-label">Price (₹)</label>
                            <input type="number" id="price" name="price" class="form-control" min="0">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="duration" class="form-label">Duration</label>
                            <input type="text" id="duration" name="duration" class="form-control" placeholder="e.g., hour, night">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-check" style="margin-top: 35px;">
                            <input type="checkbox" id="negotiable" name="negotiable" class="form-check-input">
                            <label for="negotiable" class="form-check-label">Price negotiable</label>
                        </div>
                    </div>
                </div>
                
                <h3 class="mt-4">Images</h3>
                
                <div class="form-group">
                    <label for="images" class="form-label">Upload Images (Max 5)</label>
                    <input type="file" id="images" name="images" class="form-control" accept="image/*" multiple>
                    <small class="form-text text-muted">First image will be the primary image</small>
                </div>
                
                <div id="image-preview" class="mt-3"></div>
            </div>
            
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body">
                        <h4>Additional Details</h4>
                        
                        <div class="form-group">
                            <label for="age" class="form-label">Age</label>
                            <input type="number" id="age" name="age" class="form-control" min="18" max="99">
                        </div>
                        
                        <div class="form-group">
                            <label for="services" class="form-label">Services</label>
                            <textarea id="services" name="services" class="form-control" rows="3" placeholder="Enter services separated by commas"></textarea>
                        </div>
                        
                        <h5 class="mt-3">Availability</h5>
                        
                        <div class="form-check">
                            <input type="checkbox" id="incall" name="incall" class="form-check-input" checked>
                            <label for="incall" class="form-check-label">Incall</label>
                        </div>
                        
                        <div class="form-check">
                            <input type="checkbox" id="outcall" name="outcall" class="form-check-input" checked>
                            <label for="outcall" class="form-check-label">Outcall</label>
                        </div>
                    </div>
                </div>
                
                <div class="card mt-3">
                    <div class="card-body">
                        <h4>Posting Guidelines</h4>
                        <ul class="small">
                            <li>All information must be accurate</li>
                            <li>Photos must be genuine</li>
                            <li>No illegal services</li>
                            <li>Must be 18+ years old</li>
                            <li>Respectful content only</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="mt-4">
            <button type="submit" class="btn btn-primary btn-lg">Post Ad</button>
            <a href="/user/dashboard" class="btn btn-secondary btn-lg">Cancel</a>
        </div>
    </form>
</main>

<%- include('../partials/footer') %>