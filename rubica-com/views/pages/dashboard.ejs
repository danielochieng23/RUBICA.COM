<%- include('../partials/header') %>

<main class="container py-5">
    <h1>Welcome, <%= user.username %>!</h1>
    
    <div class="dashboard-stats">
        <div class="stat-card">
            <i class="fas fa-list"></i>
            <div class="stat-value"><%= stats.totalListings %></div>
            <div class="stat-label">Total Listings</div>
        </div>
        <div class="stat-card">
            <i class="fas fa-check-circle"></i>
            <div class="stat-value"><%= stats.activeListings %></div>
            <div class="stat-label">Active Listings</div>
        </div>
        <div class="stat-card">
            <i class="fas fa-eye"></i>
            <div class="stat-value"><%= stats.views %></div>
            <div class="stat-label">Total Views</div>
        </div>
    </div>
    
    <div class="mt-5">
        <div class="row">
            <div class="col-md-8">
                <h3>Recent Listings</h3>
                <% if (recentListings.length > 0) { %>
                    <div class="list-group mt-3">
                        <% recentListings.forEach(listing => { %>
                            <div class="list-group-item">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <h5><a href="/listings/<%= listing._id %>"><%= listing.title %></a></h5>
                                        <p class="mb-1">
                                            <span class="badge <%= listing.status === 'active' ? 'badge-success' : 'badge-secondary' %>">
                                                <%= listing.status %>
                                            </span>
                                            <span class="text-muted ml-2">
                                                <i class="fas fa-eye"></i> <%= listing.stats.views %> views
                                            </span>
                                        </p>
                                    </div>
                                    <div>
                                        <a href="/listings/<%= listing._id %>/edit" class="btn btn-sm btn-secondary">Edit</a>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <p class="text-muted">You haven't posted any listings yet.</p>
                <% } %>
                
                <div class="mt-4">
                    <a href="/user/my-listings" class="btn btn-primary">View All Listings</a>
                    <a href="/listings/new/create" class="btn btn-secondary">Post New Ad</a>
                </div>
            </div>
            
            <div class="col-md-4">
                <h3>Quick Actions</h3>
                <div class="list-group mt-3">
                    <a href="/user/profile" class="list-group-item list-group-item-action">
                        <i class="fas fa-user"></i> My Profile
                    </a>
                    <a href="/user/my-listings" class="list-group-item list-group-item-action">
                        <i class="fas fa-list"></i> My Listings
                    </a>
                    <a href="/user/favorites" class="list-group-item list-group-item-action">
                        <i class="fas fa-heart"></i> My Favorites
                    </a>
                    <a href="/user/change-password" class="list-group-item list-group-item-action">
                        <i class="fas fa-key"></i> Change Password
                    </a>
                    <a href="/auth/logout" class="list-group-item list-group-item-action text-danger">
                        <i class="fas fa-sign-out-alt"></i> Logout
                    </a>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>