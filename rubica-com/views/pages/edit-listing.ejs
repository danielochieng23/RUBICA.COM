<%- include('../partials/header') %>

<main class="container py-5">
    <h1>Edit Listing</h1>
    
    <% if (error) { %>
        <div class="alert alert-error">
            <%= error %>
        </div>
    <% } %>
    
    <form action="/listings/<%= listing._id %>/edit" method="POST" enctype="multipart/form-data">
        <div class="row">
            <div class="col-md-8">
                <h3>Basic Information</h3>
                
                <div class="form-group">
                    <label for="title" class="form-label">Title *</label>
                    <input type="text" id="title" name="title" class="form-control" value="<%= listing.title %>" required maxlength="100">
                </div>
                
                <div class="form-group">
                    <label for="description" class="form-label">Description *</label>
                    <textarea id="description" name="description" class="form-control" rows="5" required maxlength="2000"><%= listing.description %></textarea>
                </div>
                
                <div class="form-group">
                    <label for="category" class="form-label">Category *</label>
                    <select id="category" name="category" class="form-control" required>
                        <option value="call-girls" <%= listing.category === 'call-girls' ? 'selected' : '' %>>Call Girls</option>
                        <option value="massages" <%= listing.category === 'massages' ? 'selected' : '' %>>Massages</option>
                        <option value="male-escorts" <%= listing.category === 'male-escorts' ? 'selected' : '' %>>Male Escorts</option>
                        <option value="transsexual" <%= listing.category === 'transsexual' ? 'selected' : '' %>>Transsexual</option>
                        <option value="adult-meetings" <%= listing.category === 'adult-meetings' ? 'selected' : '' %>>Adult Meetings</option>
                    </select>
                </div>
                
                <h3 class="mt-4">Location</h3>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="city" class="form-label">City *</label>
                            <select id="city" name="city" class="form-control" required>
                                <option value="Mumbai" <%= listing.location.city === 'Mumbai' ? 'selected' : '' %>>Mumbai</option>
                                <option value="Delhi" <%= listing.location.city === 'Delhi' ? 'selected' : '' %>>Delhi</option>
                                <option value="Bangalore" <%= listing.location.city === 'Bangalore' ? 'selected' : '' %>>Bangalore</option>
                                <option value="Kolkata" <%= listing.location.city === 'Kolkata' ? 'selected' : '' %>>Kolkata</option>
                                <option value="Chennai" <%= listing.location.city === 'Chennai' ? 'selected' : '' %>>Chennai</option>
                                <option value="Hyderabad" <%= listing.location.city === 'Hyderabad' ? 'selected' : '' %>>Hyderabad</option>
                                <option value="Pune" <%= listing.location.city === 'Pune' ? 'selected' : '' %>>Pune</option>
                                <option value="Ahmedabad" <%= listing.location.city === 'Ahmedabad' ? 'selected' : '' %>>Ahmedabad</option>
                                <option value="Jaipur" <%= listing.location.city === 'Jaipur' ? 'selected' : '' %>>Jaipur</option>
                                <option value="Goa" <%= listing.location.city === 'Goa' ? 'selected' : '' %>>Goa</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="area" class="form-label">Area</label>
                            <input type="text" id="area" name="area" class="form-control" value="<%= listing.location.area || '' %>">
                        </div>
                    </div>
                </div>
                
                <h3 class="mt-4">Contact Information</h3>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="phone" class="form-label">Phone Number *</label>
                            <input type="tel" id="phone" name="phone" class="form-control" value="<%= listing.contact.phone %>" required>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="whatsapp" class="form-label">WhatsApp</label>
                            <input type="tel" id="whatsapp" name="whatsapp" class="form-control" value="<%= listing.contact.whatsapp || '' %>">
                        </div>
                    </div>
                </div>
                
                <div class="form-check">
                    <input type="checkbox" id="hidePhone" name="hidePhone" class="form-check-input" <%= listing.contact.hidePhone ? 'checked' : '' %>>
                    <label for="hidePhone" class="form-check-label">Hide phone number in listing</label>
                </div>
                
                <h3 class="mt-4">Pricing</h3>
                
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="price" class="form-label">Price (₹)</label>
                            <input type="number" id="price" name="price" class="form-control" min="0" value="<%= listing.pricing.amount || '' %>">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label for="duration" class="form-label">Duration</label>
                            <input type="text" id="duration" name="duration" class="form-control" value="<%= listing.pricing.duration || '' %>" placeholder="e.g., hour, night">
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-check" style="margin-top: 35px;">
                            <input type="checkbox" id="negotiable" name="negotiable" class="form-check-input" <%= listing.pricing.negotiable ? 'checked' : '' %>>
                            <label for="negotiable" class="form-check-label">Price negotiable</label>
                        </div>
                    </div>
                </div>
                
                <h3 class="mt-4">Current Images</h3>
                <% if (listing.images && listing.images.length > 0) { %>
                    <div class="row">
                        <% listing.images.forEach(image => { %>
                            <div class="col-md-3 mb-3">
                                <img src="<%= image.url %>" class="img-fluid" alt="Listing image">
                            </div>
                        <% }) %>
                    </div>
                <% } %>
                
                <div class="form-group mt-3">
                    <label for="images" class="form-label">Add More Images (Max 5 total)</label>
                    <input type="file" id="images" name="images" class="form-control" accept="image/*" multiple>
                </div>
            </div>
            
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body">
                        <h4>Additional Details</h4>
                        
                        <div class="form-group">
                            <label for="age" class="form-label">Age</label>
                            <input type="number" id="age" name="age" class="form-control" min="18" max="99" value="<%= listing.age || '' %>">
                        </div>
                        
                        <div class="form-group">
                            <label for="services" class="form-label">Services</label>
                            <textarea id="services" name="services" class="form-control" rows="3" placeholder="Enter services separated by commas"><%= listing.services ? listing.services.join(', ') : '' %></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="mt-4">
            <button type="submit" class="btn btn-primary btn-lg">Update Listing</button>
            <a href="/user/my-listings" class="btn btn-secondary btn-lg">Cancel</a>
        </div>
    </form>
</main>

<%- include('../partials/footer') %>