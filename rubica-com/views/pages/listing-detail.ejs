<%- include('../partials/header') %>

<main class="container py-5">
    <div class="row">
        <div class="col-md-8">
            <h1><%= listing.title %></h1>
            
            <div class="mb-3">
                <span class="badge badge-primary"><%= listing.category %></span>
                <span class="text-muted ml-2">
                    <i class="fas fa-eye"></i> <%= listing.stats.views %> views
                </span>
                <span class="text-muted ml-2">
                    <i class="fas fa-clock"></i> Posted <%= new Date(listing.createdAt).toLocaleDateString() %>
                </span>
            </div>
            
            <% if (listing.images && listing.images.length > 0) { %>
                <div id="carouselImages" class="carousel slide mb-4" data-ride="carousel">
                    <div class="carousel-inner">
                        <% listing.images.forEach((image, index) => { %>
                            <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                                <img src="<%= image.url %>" class="d-block w-100" alt="<%= listing.title %>">
                            </div>
                        <% }) %>
                    </div>
                    <% if (listing.images.length > 1) { %>
                        <a class="carousel-control-prev" href="#carouselImages" role="button" data-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="sr-only">Previous</span>
                        </a>
                        <a class="carousel-control-next" href="#carouselImages" role="button" data-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="sr-only">Next</span>
                        </a>
                    <% } %>
                </div>
            <% } %>
            
            <div class="card mb-4">
                <div class="card-body">
                    <h3>Description</h3>
                    <p><%= listing.description %></p>
                </div>
            </div>
            
            <% if (listing.services && listing.services.length > 0) { %>
                <div class="card mb-4">
                    <div class="card-body">
                        <h3>Services</h3>
                        <div>
                            <% listing.services.forEach(service => { %>
                                <span class="badge badge-secondary mr-2 mb-2"><%= service %></span>
                            <% }) %>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
        
        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-body">
                    <h3 class="text-primary mb-3"><%= listing.formattedPrice %></h3>
                    
                    <p>
                        <i class="fas fa-map-marker-alt"></i> 
                        <%= listing.location.area ? listing.location.area + ', ' : '' %>
                        <%= listing.location.city %>
                    </p>
                    
                    <% if (listing.age) { %>
                        <p><i class="fas fa-user"></i> Age: <%= listing.age %></p>
                    <% } %>
                    
                    <% if (listing.availability) { %>
                        <p>
                            <i class="fas fa-home"></i> 
                            <%= listing.availability.incall ? 'Incall' : '' %>
                            <%= listing.availability.incall && listing.availability.outcall ? '/' : '' %>
                            <%= listing.availability.outcall ? 'Outcall' : '' %>
                        </p>
                    <% } %>
                    
                    <hr>
                    
                    <h4>Contact</h4>
                    
                    <% if (!listing.contact.hidePhone) { %>
                        <p>
                            <i class="fas fa-phone"></i> 
                            <a href="tel:<%= listing.contact.phone %>"><%= listing.contact.phone %></a>
                        </p>
                    <% } %>
                    
                    <% if (listing.contact.whatsapp) { %>
                        <p>
                            <i class="fab fa-whatsapp"></i> 
                            <a href="https://wa.me/<%= listing.contact.whatsapp.replace(/[^0-9]/g, '') %>" target="_blank">
                                WhatsApp
                            </a>
                        </p>
                    <% } %>
                    
                    <% if (user) { %>
                        <button class="btn btn-secondary btn-block favorite-btn" data-listing-id="<%= listing._id %>">
                            <i class="far fa-heart"></i> Add to Favorites
                        </button>
                    <% } else { %>
                        <a href="/auth/login" class="btn btn-secondary btn-block">
                            Login to Save
                        </a>
                    <% } %>
                </div>
            </div>
            
            <div class="card">
                <div class="card-body">
                    <h4>Safety Tips</h4>
                    <ul class="small">
                        <li>Meet in public places first</li>
                        <li>Verify the person's identity</li>
                        <li>Trust your instincts</li>
                        <li>Never send money in advance</li>
                        <li>Report suspicious behavior</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
    
    <% if (relatedListings && relatedListings.length > 0) { %>
        <div class="mt-5">
            <h3>Similar Listings</h3>
            <div class="listings-grid">
                <% relatedListings.forEach(related => { %>
                    <div class="listing-card">
                        <a href="/listings/<%= related._id %>">
                            <div class="listing-image">
                                <% if (related.images && related.images.length > 0) { %>
                                    <img src="<%= related.images[0].url %>" alt="<%= related.title %>">
                                <% } else { %>
                                    <img src="/images/placeholder.jpg" alt="<%= related.title %>">
                                <% } %>
                            </div>
                            <div class="listing-content">
                                <h4 class="listing-title"><%= related.title %></h4>
                                <div class="listing-meta">
                                    <span class="listing-location">
                                        <i class="fas fa-map-marker-alt"></i>
                                        <%= related.location.city %>
                                    </span>
                                    <span class="listing-price"><%= related.formattedPrice %></span>
                                </div>
                            </div>
                        </a>
                    </div>
                <% }) %>
            </div>
        </div>
    <% } %>
</main>

<script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.0/dist/js/bootstrap.bundle.min.js"></script>

<%- include('../partials/footer') %>